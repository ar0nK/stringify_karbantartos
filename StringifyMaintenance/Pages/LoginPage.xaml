<Page x:Class="StringifyMaintenance.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="#F5F6FA">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#111827" CornerRadius="18" Padding="32" Margin="0,0,16,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Stringify Maintenance" Foreground="#E5E7EB" FontSize="28" FontWeight="Bold" />
                <TextBlock Text="Admin access for products, users, and orders." Foreground="#9CA3AF" FontSize="14" Margin="0,12,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="18" Padding="32">
            <StackPanel VerticalAlignment="Center" Width="320" HorizontalAlignment="Center">
                <TextBlock Text="Login" FontSize="22" FontWeight="SemiBold" Foreground="#111827" />
                <TextBlock Text="Use your account credentials" Foreground="#6B7280" Margin="0,6,0,24" />

                <TextBlock Text="Email" Foreground="#374151" />
                <TextBox x:Name="EmailTextBox" Height="32" Margin="0,6,0,12" />

                <TextBlock Text="Password" Foreground="#374151" />
                <PasswordBox x:Name="PasswordBox" Height="32" Margin="0,6,0,12" />

                <TextBlock x:Name="ErrorTextBlock" Foreground="#B91C1C" TextWrapping="Wrap" Margin="0,0,0,12" />

                <Button Content="Login" Height="36" Click="LoginButton_Click" Background="#2563EB" Foreground="White" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
